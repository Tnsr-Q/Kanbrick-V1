# Node / Vite
node_modules
dist
dist-ssr
*.local

# Tauri / Rust build output (also covered by the repo-root **/target rule)
src-tauri/target
src-tauri/gen/schemas

# Bundled sidecar binary — built per host triple by scripts/prepare-sidecar.sh,
# never committed (large, platform-specific build artifact).
src-tauri/binaries/

# The JS lockfile is (re)generated on `npm install`; left uncommitted for the
# scaffold. The Rust lockfile (src-tauri/Cargo.lock) IS committed — this is a
# binary crate, so its pinned dependency graph is tracked on purpose, for
# reproducible Tauri builds that an ecosystem release can't silently break.
package-lock.json
